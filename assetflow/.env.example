# Copy this file to .env.local and fill in your Firebase values
# Firebase Console → Project Settings → Your Apps → SDK Setup & Configuration

# Set this to true only for local emulator development.
VITE_USE_FIREBASE_EMULATOR=false
# Emulator hosts used only when VITE_USE_FIREBASE_EMULATOR=true
VITE_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
