rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ─────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isRole(r) {
      return isAuth() && getRole() == r;
    }

    function isOneOfRoles(roles) {
      return isAuth() && getRole() in roles;
    }

    function isAdmin()        { return isRole('admin'); }
    function isAssetManager() { return isOneOfRoles(['admin', 'asset_manager']); }
    function isDeptHead()     { return isOneOfRoles(['admin', 'asset_manager', 'department_head']); }
    function isEmployee()     { return isAuth(); }

    function isOwner(uid)     { return isAuth() && request.auth.uid == uid; }

    // ─── users ───────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid)
                    && request.resource.data.role == 'employee';  // role hardcoded on signup
      allow update: if isOwner(uid)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])
                    || isAdmin();                                   // admin can change role/status
      allow delete: if false;
    }

    // ─── departments ─────────────────────────────────────────
    match /departments/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ─── assetCategories ─────────────────────────────────────
    match /assetCategories/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ─── assets ──────────────────────────────────────────────
    match /assets/{id} {
      allow read:   if isAuth();
      allow create: if isAssetManager();
      allow update: if isAssetManager();
      allow delete: if false;                                       // assets are never deleted
    }

    // ─── counters (asset tag counter) ────────────────────────
    match /counters/{id} {
      allow read:   if isAssetManager();
      allow write:  if isAssetManager();
    }

    // ─── allocations ─────────────────────────────────────────
    match /allocations/{id} {
      allow read:   if isAuth();
      allow create: if isAssetManager();
      allow update: if isAssetManager();
      allow delete: if false;
    }

    // ─── transferRequests ────────────────────────────────────
    match /transferRequests/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();                                    // any user can request
      allow update: if isDeptHead();                                // head/AM/admin approves
      allow delete: if false;
    }

    // ─── bookings ────────────────────────────────────────────
    match /bookings/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        isOwner(resource.data.bookedByUserId) || isAssetManager()
      );
      allow delete: if false;
    }

    // ─── maintenanceRequests ─────────────────────────────────
    match /maintenanceRequests/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();                                    // any employee can raise
      allow update: if isAssetManager();                            // AM/admin drives workflow
      allow delete: if false;
    }

    // ─── auditCycles ─────────────────────────────────────────
    match /auditCycles/{id} {
      allow read:   if isAuth();
      allow write:  if isAssetManager();
    }

    // ─── auditItems ──────────────────────────────────────────
    match /auditItems/{id} {
      allow read:   if isAuth();
      allow write:  if isAssetManager();
    }

    // ─── discrepancyReports ──────────────────────────────────
    match /discrepancyReports/{id} {
      allow read:   if isAssetManager();
      allow write:  if isAssetManager();
    }

    // ─── notifications ───────────────────────────────────────
    match /notifications/{id} {
      allow read:   if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId)               // only mark read
                    && request.resource.data.diff(resource.data).affectedKeys() == ['isRead'].toSet();
      allow create: if isAuth();                                    // service layer writes for others
      allow delete: if false;
    }

    // ─── activityLogs ────────────────────────────────────────
    match /activityLogs/{id} {
      allow read:   if isAssetManager();
      allow create: if isAuth();                                    // any action can log
      allow update: if false;                                       // immutable
      allow delete: if false;                                       // immutable
    }
  }
}
